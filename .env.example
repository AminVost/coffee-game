# MySQL database used by every application workflow.
DATABASE_URL="mysql://root:@127.0.0.1:3306/coffee_game_satarkhan"

# Required for Production. Use a random value with at least 32 characters.
AUTH_SECRET="replace-with-a-long-random-production-secret"
SESSION_DAYS=7

# Public application URL. Replace with the real HTTPS domain in Production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Payment is manual transfer / POS / cash. No online mock gateway is used.
PAYMENT_PROVIDER=manual_transfer

# Local development before obtaining SMS.ir:
# - OTP is generated dynamically.
# - The user is created in MySQL when the code is requested.
# - The code is NOT returned to the browser.
# - Read the temporary code from users.two_step_development_code.
SMS_PROVIDER=database
ALLOW_DATABASE_OTP=true

# Production SMS.ir configuration:
# SMS_PROVIDER=smsir
# ALLOW_DATABASE_OTP=false
SMSIR_API_KEY=""
SMSIR_TEMPLATE_ID=0
SMSIR_PAYMENT_APPROVED_TEMPLATE_ID=0
SMSIR_PAYMENT_REJECTED_TEMPLATE_ID=0
SMSIR_REGISTRATION_TRACKING_TEMPLATE_ID=0

SMS_OTP_TTL_MINUTES=5
SMS_OTP_MAX_ATTEMPTS=5
SMS_OTP_COOLDOWN_SECONDS=60
SMS_OTP_HOURLY_LIMIT=5
SMS_OTP_IP_HOURLY_LIMIT=20

REGISTRATION_HOLD_MINUTES=15
PAYMENT_CORRECTION_HOURS=2
