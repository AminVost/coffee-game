# mock | mysql
DATA_MODE=mock

# MySQL in WampServer
DATABASE_URL="mysql://root:@127.0.0.1:3306/coffee_game_satarkhan"

# Replace with a long random value before production.
AUTH_SECRET="change-this-local-secret-to-a-long-random-value"
SESSION_DAYS=7

# Public application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Payment remains mock until a real provider is connected.
PAYMENT_PROVIDER=mock

# mock is allowed only during local/non-production development.
# For MySQL production use SMS_PROVIDER=smsir and configure the SMS.ir values.
SMS_PROVIDER=mock
MOCK_SMS_CODE=123456
SMSIR_API_KEY=""
SMSIR_TEMPLATE_ID=0
SMS_OTP_TTL_MINUTES=5
SMS_OTP_MAX_ATTEMPTS=5
SMS_OTP_COOLDOWN_SECONDS=60

# Future integrations
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
ZARINPAL_MERCHANT_ID=""
